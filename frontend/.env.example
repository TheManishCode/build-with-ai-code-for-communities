# Copy to .env for local dev. Never commit .env -- it's gitignored.
VITE_API_BASE=http://localhost:8000

# For production builds (Vercel/Netlify/etc.), set VITE_API_BASE in the
# hosting platform's environment variables to the deployed backend URL,
# e.g. https://build-with-ai-api.onrender.com -- do not rely on this file
# or a committed .env, since Vite bakes VITE_API_BASE in at build time.
